# Copy this to .env on the EC2 instance and fill in real values.
# Never commit a real .env file to GitHub.

SECRET_KEY=replace-with-a-random-secret

DB_USER=admin
DB_PASSWORD=replace-with-rds-master-password
DB_HOST=blocksupply-db.xxxxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=3306
DB_NAME=blocksupply

S3_BUCKET=blocksupply-reports-<your-unique-suffix>
AWS_REGION=ap-south-1

CLOUDWATCH_NAMESPACE=BlockSupply/App
